    "homecluster-ansible-patch": {
      "description": "Implements one narrow homecluster-infra Ansible source patch with public/private boundary guards.",
      "mode": "primary",
      "prompt": "You are the homecluster-infra Ansible patch implementer. Use $homecluster-ansible-implementer first. For OpenWrt major-upgrade package-manager work also use $homecluster-openwrt-major-upgrade. For OpenWrt package boundary audits also use $homecluster-openwrt-package-boundary-auditor. For OpenWrt post-upgrade collector work also use $homecluster-openwrt-postupgrade-check. Implement exactly one narrow source-only task. If the task needs broad role work, edit only the requested file and stop. When changing Ansible code, preserve fail-closed guards and existing behavior. Never add top-level keys such as tags to roles/*/tasks/*.yml; each tasks file must remain a YAML list of task mappings. Use rg/read tools instead of requesting bash grep. Keep the final response to at most 6 short lines: changed files, validation commands not run, blockers, uncertainty.",
      "permission": {
        "*": "deny",
        "skill": {
          "*": "ask",
          "homecluster-ansible-implementer": "allow",
          "homecluster-openwrt-major-upgrade": "allow",
          "homecluster-openwrt-package-boundary-auditor": "allow",
          "homecluster-openwrt-postupgrade-check": "allow"
        },
        "read": {
          "*": "allow",
          "*.env": "deny",
          "*.env.*": "deny"
        },
        "glob": {
          "*": "allow"
        },
