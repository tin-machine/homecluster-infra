#!/bin/sh

set -eu

MODE="${1:-}"
MOUNTPOINT="{{ k3s_local_storage_mountpoint }}"
STATE_DIR="{{ k3s_local_storage_state_dir }}"
STATE_FILE="{{ k3s_local_storage_node_password_state_path }}"
CA_HASH_STATE_FILE="{{ k3s_local_storage_server_ca_hash_state_path }}"
CLUSTER_TOKEN_FILE="{{ k3s_local_storage_cluster_token_path }}"
RESET_IDENTITY_WHEN_LOCAL_PASSWORD_MISSING="{{ k3s_local_storage_reset_identity_when_local_password_missing | bool | ternary('true', 'false') }}"
AGENT_DIR="${MOUNTPOINT}/agent"
LOCAL_DIR="/etc/rancher/node"
LOCAL_FILE="${LOCAL_DIR}/password"

wait_for_mount() {
  for _ in $(seq 1 30); do
    if findmnt -T "${MOUNTPOINT}" >/dev/null 2>&1; then
      return 0
    fi
    sleep 1
  done

  echo "mountpoint is not ready: ${MOUNTPOINT}" >&2
  return 1
}

ensure_dirs() {
  install -d -m 0700 "${STATE_DIR}"
  install -d -m 0755 "${LOCAL_DIR}"
}

current_token_ca_hash() {
  [ -s "${CLUSTER_TOKEN_FILE}" ] || return 1
  token="$(tr -d '\r\n' < "${CLUSTER_TOKEN_FILE}")"
  case "${token}" in
    K10*::*)
      rest="${token#K10}"
      printf '%s\n' "${rest%%::*}"
      ;;
    *)
      return 1
      ;;
  esac
}

agent_identity_exists() {
  [ -e "${AGENT_DIR}/server-ca.crt" ] ||
    [ -e "${AGENT_DIR}/client-kubelet.crt" ] ||
    [ -e "${AGENT_DIR}/kubelet.kubeconfig" ]
}

reset_agent_identity() {
  rm -f "${LOCAL_FILE}" "${STATE_FILE}" "${CA_HASH_STATE_FILE}"
  rm -f \
    "${AGENT_DIR}"/client-*.crt \
    "${AGENT_DIR}"/client-*.key \
    "${AGENT_DIR}"/serving-kubelet.crt \
    "${AGENT_DIR}"/serving-kubelet.key \
    "${AGENT_DIR}"/server-ca.crt \
    "${AGENT_DIR}"/*.kubeconfig \
    "${AGENT_DIR}/etc/k3s-agent-load-balancer.json"
}

restore_password() {
  wait_for_mount
  ensure_dirs

  if [ "${RESET_IDENTITY_WHEN_LOCAL_PASSWORD_MISSING}" = "true" ] && [ ! -s "${LOCAL_FILE}" ]; then
    if [ -s "${STATE_FILE}" ] || [ -s "${CA_HASH_STATE_FILE}" ] || agent_identity_exists; then
      echo "local node password is missing; resetting persisted agent identity" >&2
      reset_agent_identity
    fi
    return 0
  fi

  current_hash="$(current_token_ca_hash 2>/dev/null || true)"
  stored_hash=""
  if [ -s "${CA_HASH_STATE_FILE}" ]; then
    stored_hash="$(tr -d '\r\n' < "${CA_HASH_STATE_FILE}")"
  fi

  if [ -n "${current_hash}" ] && [ -n "${stored_hash}" ] && [ "${current_hash}" != "${stored_hash}" ]; then
    echo "k3s server CA hash changed; resetting persisted agent identity" >&2
    reset_agent_identity
    return 0
  fi

  if [ -n "${current_hash}" ] && [ -z "${stored_hash}" ] && agent_identity_exists; then
    echo "k3s server CA hash state is missing; resetting existing agent identity once" >&2
    reset_agent_identity
    return 0
  fi

  if [ -s "${STATE_FILE}" ]; then
    install -m 0600 "${STATE_FILE}" "${LOCAL_FILE}"
  fi
}

persist_password() {
  wait_for_mount || exit 0
  ensure_dirs

  for _ in $(seq 1 60); do
    if [ -s "${LOCAL_FILE}" ]; then
      install -m 0600 "${LOCAL_FILE}" "${STATE_FILE}"
      current_hash="$(current_token_ca_hash 2>/dev/null || true)"
      if [ -n "${current_hash}" ]; then
        printf '%s\n' "${current_hash}" > "${CA_HASH_STATE_FILE}"
        chmod 0600 "${CA_HASH_STATE_FILE}"
      fi
      return 0
    fi
    sleep 1
  done

  echo "node password was not created under ${LOCAL_FILE}" >&2
  return 0
}

case "${MODE}" in
  restore)
    restore_password
    ;;
  persist)
    persist_password
    ;;
  *)
    echo "usage: $0 restore|persist" >&2
    exit 2
    ;;
esac
