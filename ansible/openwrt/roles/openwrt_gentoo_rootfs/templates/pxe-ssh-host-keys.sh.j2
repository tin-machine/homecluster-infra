#!/bin/sh
set -eu

CONFIG_FILE="{{ openwrt_gentoo_ssh_host_keys_config_path }}"

if [ -r "$CONFIG_FILE" ]; then
  # shellcheck disable=SC1090
  . "$CONFIG_FILE"
fi

ROLE_ENV_FILE="${PXE_SSH_HOST_ROLE_ENV_FILE:-/run/dhcp/role.env}"
STORE_ROOT="${PXE_SSH_HOST_KEY_STORE_ROOT:-/run/pxe-bootstrap/logs/ssh-host-keys}"
LOCAL_DIR="${PXE_SSH_HOST_KEY_LOCAL_DIR:-/etc/ssh}"
KEY_TYPES="${PXE_SSH_HOST_KEY_TYPES:-ed25519}"
CERTS_ENABLED="${PXE_SSH_HOST_CERTIFICATES_ENABLED:-1}"
CERT_CONFIG="${PXE_SSH_HOST_CERTIFICATE_CONFIG:-/etc/ssh/sshd_config.d/20-pxe-host-certificates.conf}"

log() {
  printf '%s\n' "pxe-ssh-host-keys: $*" >&2
}

die() {
  log "$*"
  exit 1
}

role_env_value() {
  awk -F= -v key="$1" '
    $1 == key {
      print substr($0, length($1) + 2)
      exit
    }
  ' "$ROLE_ENV_FILE"
}

[ -r "$ROLE_ENV_FILE" ] || die "role env not found: $ROLE_ENV_FILE"

OVERLAY_ID="$(role_env_value OVERLAY_ID || true)"
case "$OVERLAY_ID" in
  ""|*[!A-Za-z0-9_.-]*)
    die "invalid OVERLAY_ID: ${OVERLAY_ID:-empty}"
    ;;
esac

[ -d "$STORE_ROOT" ] || die "host key store root is not mounted: $STORE_ROOT"

STORE_DIR="${STORE_ROOT}/${OVERLAY_ID}"
CERT_CONFIG_DIR="$(dirname "$CERT_CONFIG")"

umask 077
mkdir -p "$STORE_DIR" "$LOCAL_DIR" "$CERT_CONFIG_DIR"
chmod 0700 "$STORE_DIR" 2>/dev/null || true

cert_tmp="${CERT_CONFIG}.$$"
rm -f "$cert_tmp"
has_cert=0

for key_type in $KEY_TYPES; do
  case "$key_type" in
    ed25519|rsa|ecdsa)
      ;;
    *)
      die "unsupported host key type: $key_type"
      ;;
  esac

  store_key="${STORE_DIR}/ssh_host_${key_type}_key"
  store_pub="${store_key}.pub"
  local_key="${LOCAL_DIR}/ssh_host_${key_type}_key"
  local_pub="${local_key}.pub"

  if [ -s "$store_key" ] && [ ! -s "$store_pub" ]; then
    ssh-keygen -y -f "$store_key" > "$store_pub"
    chmod 0644 "$store_pub"
    log "recreated ${key_type} host public key from persistent private key"
  fi

  if [ ! -s "$store_key" ]; then
    tmp_key="${STORE_DIR}/.ssh_host_${key_type}_key.$$"
    rm -f "$tmp_key" "${tmp_key}.pub"
    ssh-keygen -q -t "$key_type" -N "" -C "pxe-${OVERLAY_ID}" -f "$tmp_key"
    chmod 0600 "$tmp_key"
    chmod 0644 "${tmp_key}.pub"
    mv "$tmp_key" "$store_key"
    mv "${tmp_key}.pub" "$store_pub"
    log "generated persistent ${key_type} host key"
  fi

  install -m 0600 "$store_key" "$local_key"
  install -m 0644 "$store_pub" "$local_pub"

  store_cert="${STORE_DIR}/ssh_host_${key_type}_key-cert.pub"
  local_cert="${LOCAL_DIR}/ssh_host_${key_type}_key-cert.pub"
  if [ "$CERTS_ENABLED" = "1" ] && [ -s "$store_cert" ]; then
    install -m 0644 "$store_cert" "$local_cert"
    if [ "$has_cert" -eq 0 ]; then
      printf '%s\n' "# Generated by pxe-ssh-host-keys.sh" > "$cert_tmp"
    fi
    printf 'HostCertificate %s\n' "$local_cert" >> "$cert_tmp"
    has_cert=1
  else
    rm -f "$local_cert"
  fi
done

if [ "$has_cert" -eq 1 ]; then
  chmod 0644 "$cert_tmp"
  mv "$cert_tmp" "$CERT_CONFIG"
else
  rm -f "$cert_tmp" "$CERT_CONFIG"
fi

log "host keys prepared for ${OVERLAY_ID}"
