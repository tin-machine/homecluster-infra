# {{ ansible_managed }}
{% set tftp_host_item = item if item is defined and item is mapping else {} -%}
{% set global_kernel_image = tftp_host_item.rpi_kernel_image | default(openwrt_gentoo_rpi_kernel_image | default('', true), true) | trim -%}
{% set global_initramfs = tftp_host_item.rpi_initramfs | default(openwrt_gentoo_rpi_initramfs | default('', true), true) | trim -%}
{% set global_device_tree = tftp_host_item.rpi_device_tree | default(openwrt_gentoo_rpi_device_tree | default('', true), true) | trim -%}
{% set rpi4_kernel_image = tftp_host_item.rpi4_kernel_image | default(openwrt_gentoo_rpi4_kernel_image | default('', true), true) | trim -%}
{% set rpi4_initramfs = tftp_host_item.rpi4_initramfs | default(openwrt_gentoo_rpi4_initramfs | default('', true), true) | trim -%}
{% set rpi4_device_tree = tftp_host_item.rpi4_device_tree | default(openwrt_gentoo_rpi4_device_tree | default('', true), true) | trim -%}
{% set rpi5_kernel_image = tftp_host_item.rpi5_kernel_image | default(openwrt_gentoo_rpi5_kernel_image | default('', true), true) | trim -%}
{% set rpi5_initramfs = tftp_host_item.rpi5_initramfs | default(openwrt_gentoo_rpi5_initramfs | default('', true), true) | trim -%}
{% set rpi5_device_tree = tftp_host_item.rpi5_device_tree | default(openwrt_gentoo_rpi5_device_tree | default('', true), true) | trim -%}
{% set rpi5_extra_config = tftp_host_item.rpi5_extra_config | default(openwrt_gentoo_rpi5_extra_config | default('', true), true) | trim -%}
{% set rpi5_pciex1_raw = tftp_host_item.rpi5_pciex1_enabled | default(none) -%}
{% set rpi5_pciex1_enabled = (rpi5_pciex1_raw | bool) if rpi5_pciex1_raw is not none else (openwrt_gentoo_rpi5_pciex1_enabled | default(false) | bool) -%}
{% set model_filter = openwrt_gentoo_rpi_model_filter_config | default(false) | bool -%}
{% set model_initramfs = model_filter and ((rpi4_initramfs | length > 0) or (rpi5_initramfs | length > 0)) -%}
{% set rpi4_effective_initramfs = rpi4_initramfs if (rpi4_initramfs | length > 0) else global_initramfs -%}
{% set rpi5_effective_initramfs = rpi5_initramfs if (rpi5_initramfs | length > 0) else global_initramfs -%}
[all]
arm_64bit={{ 1 if openwrt_gentoo_rpi_arm64 | bool else 0 }}
enable_uart={{ 1 if openwrt_gentoo_rpi_enable_uart | bool else 0 }}
bootcode_delay={{ openwrt_gentoo_rpi_bootcode_delay }}

{% if (global_initramfs | length > 0) and not model_initramfs -%}
initramfs {{ global_initramfs }} followkernel
{% endif -%}

{% if model_filter -%}
[pi4]
{% if rpi4_kernel_image | length > 0 -%}
kernel={{ rpi4_kernel_image }}
{% endif -%}
{% if model_initramfs and (rpi4_effective_initramfs | length > 0) -%}
initramfs {{ rpi4_effective_initramfs }} followkernel
{% endif -%}
{% if rpi4_device_tree | length > 0 -%}
device_tree={{ rpi4_device_tree }}
{% endif -%}

[pi5]
{% if rpi5_kernel_image | length > 0 -%}
kernel={{ rpi5_kernel_image }}
{% endif -%}
{% if model_initramfs and (rpi5_effective_initramfs | length > 0) -%}
initramfs {{ rpi5_effective_initramfs }} followkernel
{% endif -%}
{% if rpi5_device_tree | length > 0 -%}
device_tree={{ rpi5_device_tree }}
{% endif -%}
{% if rpi5_pciex1_enabled -%}
dtparam=pciex1
{% endif -%}
{% if rpi5_extra_config | length > 0 -%}
{{ rpi5_extra_config }}
{% endif -%}

[all]
{% else -%}
{% if global_kernel_image | length > 0 -%}
kernel={{ global_kernel_image }}
{% endif -%}

{% if global_device_tree | length > 0 -%}
device_tree={{ global_device_tree }}
{% endif -%}
{% endif -%}

{% if openwrt_gentoo_rpi_extra_config | default('', true) | trim | length > 0 -%}
{{ openwrt_gentoo_rpi_extra_config | trim }}
{% endif -%}
