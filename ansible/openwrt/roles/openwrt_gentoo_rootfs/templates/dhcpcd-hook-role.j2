#!/bin/sh
# Managed by Ansible (openwrt_gentoo_rootfs)

set -eu

ROLE_FILE="{{ openwrt_gentoo_role_output_path }}"
ROLE_ENV_FILE="{{ openwrt_gentoo_role_env_output_path }}"
OPTION_KEY="{{ openwrt_gentoo_dhcp_option_key }}"
OPTION_SEPARATOR="{{ openwrt_gentoo_option_separator }}"
DEFAULT_STAGE="{{ openwrt_gentoo_stage_label | default('') }}"

{% if openwrt_gentoo_dhcp_hook_debug | default(false) %}
DEBUG_LOG="{{ openwrt_gentoo_dhcp_hook_debug_log | default('/run/dhcp/dhcpcd-hook.log') }}"
mkdir -p "$(dirname "$DEBUG_LOG")"
{
  timestamp="$(date -u '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null || date '+%Y-%m-%dT%H:%M:%SZ')"
  printf -- '%s reason=%s interface=%s\\n' "$timestamp" "${reason:-}" "${interface:-}"
  env | sort
  printf -- '---\\n'
} >> "$DEBUG_LOG" 2>&1
{% endif %}

case "${reason:-}" in
  BOUND|RENEW|REBIND|REBOOT)
    VALUE="$(eval "printf '%s' \"\${${OPTION_KEY}:-}\"")"
    ;;
  *)
    exit 0
    ;;
esac

if [ -n "$VALUE" ]; then
  overlay_id=""
  role=""
  roles=""
  stage="$DEFAULT_STAGE"
  OLDIFS="$IFS"
  IFS='
'
  set -- $(printf '%s' "$VALUE" | perl -pe 's/,(?=[A-Za-z_]+=)/\n/g')
  IFS="$OLDIFS"
  for kv in "$@"; do
    kv_clean="$(printf '%s' "$kv" | tr -d ' \t')"
    [ -z "$kv_clean" ] && continue
    key="${kv_clean%%=*}"
    val="${kv_clean#*=}"
    [ -z "$key" ] && continue
    [ "$key" = "$val" ] && continue
    key_lc="$(printf '%s' "$key" | tr '[:upper:]' '[:lower:]')"
    case "$key_lc" in
      overlay_id|overlay) overlay_id="$val" ;;
      role) role="$val" ;;
      roles) roles="$val" ;;
      stage|env|environment) stage="$val" ;;
    esac
  done
  if [ -n "$ROLE_FILE" ]; then
    mkdir -p "$(dirname "$ROLE_FILE")"
    printf '%s\n' "$VALUE" > "$ROLE_FILE"
  fi
  if [ -z "$roles" ] && [ -n "$role" ]; then
    roles="$role"
  fi
  {
    [ -n "$overlay_id" ] && printf 'OVERLAY_ID=%s\n' "$overlay_id"
    [ -n "$role" ] && printf 'ROLE=%s\n' "$role"
    [ -n "$roles" ] && printf 'ROLES=%s\n' "$roles"
    [ -n "$stage" ] && printf 'STAGE=%s\n' "$stage"
    printf 'RAW_OPTION_224=%s\n' "$VALUE"
  } > "$ROLE_ENV_FILE"
else
  if [ -n "$ROLE_FILE" ]; then
    rm -f "$ROLE_FILE"
  fi
  rm -f "$ROLE_ENV_FILE"
fi
