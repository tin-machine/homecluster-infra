# Generated by Ansible
# Raspberry Pi SD-assisted network root boot

[all]
enable_uart={{ '1' if rpi_enable_uart else '0' }}
arm_64bit={{ '1' if rpi_arm_64bit else '0' }}

{% if 'pi3' in rpi_enabled_models_normalized %}
[pi3]
kernel={{ rpi_kernel8_image }}
initramfs initramfs-bcm27xx.img followkernel
cmdline=cmdline-pi3.txt

{% endif %}
{% if 'pi4' in rpi_enabled_models_normalized %}
[pi4]
kernel={{ rpi_kernel8_image }}
initramfs initramfs-bcm27xx.img followkernel
cmdline=cmdline-pi4.txt

{% endif %}
{% if 'pi5' in rpi_enabled_models_normalized %}
[pi5]
kernel={{ rpi_pi5_kernel_image }}
initramfs initramfs-pi5.img followkernel
cmdline=cmdline-pi5.txt

{% endif %}
[all]
